    {
      "id": "h6", "category": "history",
      "en": "Do you have any allergies?",
      "ko": "알레르기가 있으십니까?",
      "fr": "Avez-vous des allergies?",
      "sw": "Je, una mzio wowote?"
    },
    {
      "id": "h7", "category": "history",
      "en": "Are you taking any medication?",
      "ko": "현재 복용 중인 약이 있으십니까?",
      "fr": "Prenez-vous des médicaments?",
      "sw": "Je, unachukua dawa yoyote?"
    },
    {
      "id": "h8", "category": "history",
      "en": "How many days have you been sick?",
      "ko": "며칠 동안 아프셨습니까?",
      "fr": "Depuis combien de jours êtes-vous malade?",
      "sw": "Umekuwa mgonjwa kwa siku ngapi?"
    },
    {
      "id": "e1", "category": "examination",
      "en": "I need to take your temperature.",
      "ko": "체온을 측정하겠습니다.",
      "fr": "Je dois prendre votre température.",
      "sw": "Ninahitaji kupima joto lako."
    },
    {
      "id": "e2", "category": "examination",
      "en": "Please breathe deeply.",
      "ko": "깊게 숨을 쉬어 주세요.",
      "fr": "Respirez profondément, s'il vous plaît.",
      "sw": "Tafadhali pumua kwa kina."
    },
    {
      "id": "e3", "category": "examination",
      "en": "Open your mouth, please.",
      "ko": "입을 벌려 주세요.",
      "fr": "Ouvrez la bouche, s'il vous plaît.",
      "sw": "Tafadhali fungua kinywa chako."
    },
    {
      "id": "e4", "category": "examination",
      "en": "Please lie down.",
      "ko": "누워 주세요.",
      "fr": "Allongez-vous, s'il vous plaît.",
      "sw": "Tafadhali lala chini."
    },
    {
      "id": "e5", "category": "examination",
      "en": "I am going to measure your arm.",
      "ko": "팔 둘레를 측정하겠습니다.",
      "fr": "Je vais mesurer votre bras.",
      "sw": "Nitapima mkono wako."
    },
    {
      "id": "i1", "category": "instructions",
      "en": "Take this medicine twice a day.",
      "ko": "이 약을 하루에 두 번 드세요.",
      "fr": "Prenez ce médicament deux fois par jour.",
      "sw": "Chukua dawa hii mara mbili kwa siku."
    },
    {
      "id": "i2", "category": "instructions",
      "en": "Drink plenty of clean water.",
      "ko": "깨끗한 물을 많이 드세요.",
      "fr": "Buvez beaucoup d'eau propre.",
      "sw": "Kunywa maji mengi safi."
    },
    {
      "id": "i3", "category": "instructions",
      "en": "Come back in 3 days, or sooner if worse.",
      "ko": "3일 후에 다시 오세요. 나빠지면 바로 오세요.",
      "fr": "Revenez dans 3 jours, ou plus tôt si ça empire.",
      "sw": "Rudi baada ya siku 3, au mapema zaidi ukizidi kuumwa."
    },
    {
      "id": "i4", "category": "instructions",
      "en": "Finish all of the medication.",
      "ko": "약을 끝까지 다 드세요.",
      "fr": "Prenez tous les médicaments jusqu'au bout.",
      "sw": "Maliza dawa zote."
    },
    {
      "id": "i5", "category": "instructions",
      "en": "Rest and eat small meals often.",
      "ko": "쉬고 조금씩 자주 드세요.",
      "fr": "Reposez-vous et mangez de petites portions souvent.",
      "sw": "Pumzika na kula kidogo kidogo mara nyingi."
    },
    {
      "id": "em1", "category": "emergency",
      "en": "This is serious. You need to go to the hospital.",
      "ko": "심각한 상태입니다. 병원에 가야 합니다.",
      "fr": "C'est grave. Vous devez aller à l'hôpital.",
      "sw": "Hali ni mbaya. Unahitaji kwenda hospitali."
    },
    {
      "id": "em2", "category": "emergency",
      "en": "Call for help immediately!",
      "ko": "즉시 도움을 요청하세요!",
      "fr": "Appelez à l'aide immédiatement!",
      "sw": "Omba msaada sasa hivi!"
    },
    {
      "id": "em3", "category": "emergency",
      "en": "Do not move the patient.",
      "ko": "환자를 움직이지 마세요.",
      "fr": "Ne bougez pas le patient.",
      "sw": "Usimhamishie mgonjwa."
    },
    {
      "id": "em4", "category": "emergency",
      "en": "The patient is not breathing. Begin CPR.",
      "ko": "환자가 숨을 쉬지 않습니다. 심폐소생술을 시작하세요.",
      "fr": "Le patient ne respire pas. Commencez la RCP.",
      "sw": "Mgonjwa hapumui. Anza CPR."
    }
  ]
