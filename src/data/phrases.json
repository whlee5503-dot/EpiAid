  "phrases": [
    {
      "id": "g1", "category": "greeting",
      "en": "Hello, I am a health worker.",
      "ko": "안녕하세요, 저는 의료 종사자입니다.",
      "fr": "Bonjour, je suis un agent de santé.",
      "sw": "Habari, mimi ni mfanyakazi wa afya."
    },
    {
      "id": "g2", "category": "greeting",
      "en": "I need to examine you. Do you consent?",
      "ko": "진찰이 필요합니다. 동의하십니까?",
      "fr": "Je dois vous examiner. Êtes-vous d'accord?",
      "sw": "Ninahitaji kukuchunguza. Je, unakubaliana?"
    },
    {
      "id": "g3", "category": "greeting",
      "en": "Do you speak [language]?",
      "ko": "[언어]를 하실 수 있으십니까?",
      "fr": "Parlez-vous [langue]?",
      "sw": "Je, unazungumza [lugha]?"
    },
    {
      "id": "p1", "category": "pain",
      "en": "Where does it hurt?",
      "ko": "어디가 아프세요?",
      "fr": "Où avez-vous mal?",
      "sw": "Unaumia wapi?"
    },
    {
      "id": "p2", "category": "pain",
      "en": "How long have you had this pain?",
      "ko": "이 통증이 얼마나 됐습니까?",
      "fr": "Depuis combien de temps avez-vous cette douleur?",
      "sw": "Maumivu haya yamekuwa kwa muda gani?"
    },
    {
      "id": "p3", "category": "pain",
      "en": "Is the pain severe, moderate, or mild?",
      "ko": "통증이 심합니까, 보통입니까, 아니면 가볍습니까?",
      "fr": "La douleur est-elle sévère, modérée ou légère?",
      "sw": "Maumivu ni makali, wastani, au kidogo?"
    },
    {
      "id": "p4", "category": "pain",
      "en": "Point to where the pain is.",
      "ko": "통증이 있는 곳을 가리켜 주세요.",
      "fr": "Montrez-moi où vous avez mal.",
      "sw": "Nionyeshe mahali maumivu yalipo."
    },
    {
      "id": "p5", "category": "pain",
      "en": "Does it hurt when I press here?",
      "ko": "여기를 누르면 아프십니까?",
      "fr": "Est-ce que ça fait mal quand j'appuie ici?",
      "sw": "Je, inakuumiza ninapobonyeza hapa?"
    },
    {
      "id": "h1", "category": "history",
      "en": "Do you have a fever?",
      "ko": "열이 있으십니까?",
      "fr": "Avez-vous de la fièvre?",
      "sw": "Je, una homa?"
    },
    {
      "id": "h2", "category": "history",
      "en": "Do you have diarrhea?",
      "ko": "설사를 하십니까?",
      "fr": "Avez-vous la diarrhée?",
      "sw": "Je, una kuhara?"
    },
    {
      "id": "h3", "category": "history",
      "en": "Do you have vomiting?",
      "ko": "구토를 하십니까?",
      "fr": "Avez-vous des vomissements?",
      "sw": "Je, una kutapika?"
    },
    {
      "id": "h4", "category": "history",
      "en": "Do you have a cough?",
      "ko": "기침을 하십니까?",
      "fr": "Avez-vous une toux?",
      "sw": "Je, una kikohozi?"
    },
    {
      "id": "h5", "category": "history",
      "en": "Are you pregnant?",
